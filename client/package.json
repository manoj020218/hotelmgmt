{
  "name": "hotel-qr-client",
  "version": "1.0.0",
  "private": true,
  "type": "module",
  "scripts": {
    "dev":             "vite",
    "build":           "vite build",
    "preview":         "vite preview",
    "test":            "vitest run",
    "test:ui":         "vitest --ui",

    "build:kds":       "vite build --mode kds",
    "build:waiter":    "vite build --mode waiter",

    "deploy":          "vite build && node ../deploy/upload-dist.mjs admin",
    "deploy:kds":      "vite build --mode kds && node ../deploy/upload-dist.mjs kds",
    "deploy:waiter":   "vite build --mode waiter && node ../deploy/upload-dist.mjs waiter",
    "deploy:all":      "pnpm run deploy && pnpm run deploy:kds && pnpm run deploy:waiter",

    "cap:init:kds":    "cap add android --config capacitor.kds.config.ts",
    "cap:init:waiter": "cap add android --config capacitor.waiter.config.ts",

    "sync:kds":        "pnpm build:kds && cap sync android --config capacitor.kds.config.ts",
    "sync:waiter":     "pnpm build:waiter && cap sync android --config capacitor.waiter.config.ts",

    "open:kds":        "cap open android --config capacitor.kds.config.ts",
    "open:waiter":     "cap open android --config capacitor.waiter.config.ts"
  },
  "dependencies": {
    "@capacitor/android": "^8.4.1",
    "@capacitor/core": "^8.4.1",
    "@react-pdf/renderer": "^3.3.8",
    "axios": "^1.6.7",
    "firebase": "^10.8.0",
    "qrcode": "^1.5.3",
    "react": "^18.2.0",
    "react-dom": "^18.2.0",
    "react-router-dom": "^6.22.0",
    "socket.io-client": "^4.6.1",
    "zustand": "^4.5.2"
  },
  "devDependencies": {
    "@capacitor/cli": "^8.4.1",
    "@testing-library/jest-dom": "^6.4.2",
    "@testing-library/react": "^14.2.1",
    "@testing-library/user-event": "^14.5.2",
    "@vitejs/plugin-react": "^4.2.1",
    "@vitest/ui": "^1.3.1",
    "autoprefixer": "^10.4.17",
    "jsdom": "^24.0.0",
    "postcss": "^8.4.35",
    "tailwindcss": "^3.4.1",
    "vite": "^5.1.0",
    "vite-plugin-pwa": "^0.17.5",
    "vitest": "^1.3.1"
  },
  "pnpm": {
    "onlyBuiltDependencies": [
      "esbuild"
    ]
  }
}
