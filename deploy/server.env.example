# Copy to /var/www/hotelqr/server/.env on the VPS
# Never commit the real .env — this file is the template

NODE_ENV=production
PORT=5000

# MongoDB
MONGO_URI=mongodb://localhost:27017/hotelqr
# or Atlas: MONGO_URI=mongodb+srv://user:pass@cluster.mongodb.net/hotelqr

# JWT
JWT_SECRET=change_this_to_a_long_random_secret_64_chars
JWT_REFRESH_SECRET=change_this_to_another_long_random_secret_64_chars
JWT_EXPIRES_IN=15m
JWT_REFRESH_EXPIRES_IN=30d

# Public-facing server URL (used to build QR image URLs and receipt URLs)
VPS_PUBLIC_URL=https://hotelqr.admin.iotsoft.in

# CORS — all three subdomains + https://localhost for Capacitor WebView
CLIENT_URL=https://hotelqr.admin.iotsoft.in,https://hotelqr.kds.iotsoft.in,https://hotelqr.waiter.iotsoft.in,https://localhost

# Frontend URL (used inside QR code content that customers scan)
FRONTEND_URL=https://hotelqr.admin.iotsoft.in

# File uploads — absolute path on the VPS
UPLOADS_DIR=/var/www/hotelqr/uploads

# Firebase Admin SDK
# Project: hotelqr-8be21
# Service account: firebase-adminsdk-fbsvc@hotelqr-8be21.iam.gserviceaccount.com
# Copy hotelqr-8be21-firebase-adminsdk-fbsvc-59b18d680e.json to the VPS (NOT in the repo)
# then set the path here:
GOOGLE_APPLICATION_CREDENTIALS=/var/www/hotelqr/hotelqr-8be21-firebase-adminsdk.json
